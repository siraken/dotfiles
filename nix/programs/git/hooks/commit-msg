#!/bin/bash

BRANCH_NAME=$(git symbolic-ref --short HEAD 2>/dev/null) || exit 0

FIRST_LINE=$(head -n 1 "$1")

# Skip merge commits
MERGE_REGEX='^Merge '
if [[ "$FIRST_LINE" =~ $MERGE_REGEX ]]; then
    exit 0
fi

TICKET_ID_REGEX='(d|b)/([0-9]+)'

if [[ $BRANCH_NAME =~ $TICKET_ID_REGEX ]]; then
    TICKET_ID=$(echo "${BASH_REMATCH[2]}" | sed 's/0*\([0-9]*[0-9]$\)/\1/g')
    EXPECTED_PREFIX="TK-${TICKET_ID}"
    # Check: first line must start with the correct TK-XXXX
    if [[ "$FIRST_LINE" != "$EXPECTED_PREFIX"* ]]; then
        echo "ERROR: Commit message must start with '$EXPECTED_PREFIX' (branch: '$BRANCH_NAME')."
        echo "Example: $EXPECTED_PREFIX fix something"
        exit 1
    fi
fi
