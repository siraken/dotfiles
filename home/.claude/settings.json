{
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.aws.amazon.com)",
      "WebFetch(domain:cloud.google.com)",
      "WebFetch(domain:docs.docker.com)",
      "WebFetch(domain:developers.cloudflare.com)",

      "WebFetch(domain:react.dev)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:vuejs.org)",
      "WebFetch(domain:svelte.dev)",
      "WebFetch(domain:php.net)",

      "WebFetch(domain:nixos.org)",
      "WebFetch(domain:developer.mozilla.org)",

      "WebFetch(domain:www.xserver.ne.jp)",
      "WebFetch(domain:www.xdomain.ne.jp)",
      "WebFetch(domain:bizmw.jp)",
      "WebFetch(domain:www.ntt.com)"
    ],
    "deny": [
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(.dev.vars)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.production)",
      "Write(.dev.vars)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(python -m pip install:*)",
      "Bash(python3 -m pip install:*)"
    ],
    "ask": [
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(npx:*)",
      "Bash(bunx:*)",
      "Bash(pnpx:*)",
      "Bash(pnpm dlx:*)",
      "Bash(yarn dlx:*)",
      "Bash(pipx:*)",
      "Bash(deno run:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)"
    ]
  },
  "model": "claude-opus-4-6[1m]",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": []
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Codeが許可を求めています\" with title \"Claude Code\" subtitle \"hooks: Notification\" sound name \"Glass\"'"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Codeがユーザー入力を待機しています\" with title \"Claude Code\" subtitle \"hooks: Notification\" sound name \"Glass\"'"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude CodeがMCPツール抽出のための入力を求めています\" with title \"Claude Code\" subtitle \"hooks: Notification\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"タスクが終了しました\" with title \"Claude Code\" subtitle \"hooks: Stop\"'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "laravel-boost@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "discord@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "figma@claude-plugins-official": true
  },
  "language": "日本語",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "tui": "default",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "preferredNotifChannel": "terminal_bell",
  "voiceEnabled": true
}
